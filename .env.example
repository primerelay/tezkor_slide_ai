# App
NODE_ENV=development
PORT=3000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tezkor
DATABASE_PASSWORD=tezkor123
DATABASE_NAME=tezkor_slide_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Image sources (FREE stock photos)
# Unsplash: https://unsplash.com/developers
# Pexels: https://www.pexels.com/api/
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Paid image fallback (OpenRouter) - set to false to disable
IMAGE_OPENROUTER_ENABLED=false
IMAGE_GENERATION_MODEL=google/gemini-2.5-flash-image

# Storage
STORAGE_PATH=./storage

# Admin (Telegram)
ADMIN_TELEGRAM_IDS=123456789
ADMIN_USERNAME=your_admin_username

# Payment Cards
HUMO_CARD_NUMBER=9860 1234 5678 9012
HUMO_CARD_OWNER=Ism Familiya
UZCARD_CARD_NUMBER=8600 1234 5678 9012
UZCARD_CARD_OWNER=Ism Familiya

# Required Channel (users must join)
REQUIRED_CHANNEL_USERNAME=your_channel
REQUIRED_CHANNEL_URL=https://t.me/your_channel

# Admin Panel
ADMIN_PHONE=998901234567
ADMIN_PASSWORD=your_secure_password_here
ADMIN_NAME=Admin
JWT_SECRET=your_jwt_secret_key_here

# Pricing
CREDITS_PER_PRESENTATION=1
DEFAULT_FREE_CREDITS=3

# Mini App URL (HTTPS required for Telegram)
MINI_APP_URL=https://yourdomain.com/mini-app
