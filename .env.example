# App
NODE_ENV=development
PORT=3000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tezkor
DATABASE_PASSWORD=tezkor123
DATABASE_NAME=tezkor_slide_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Providers (Gemini first for MVP)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (optional, for future use)
OPENROUTER_API_KEY=

# Anthropic (optional, for future use)
ANTHROPIC_API_KEY=

# Image sources (hybrid). Priority: Unsplash -> Pexels (both FREE) -> OpenRouter (PAID).
# Provide at least one free stock key to keep per-deck image cost at $0.
# Unsplash: https://unsplash.com/developers  | Pexels: https://www.pexels.com/api/
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
# Paid fallback: generate an image via OpenRouter (reuses OPENROUTER_API_KEY above)
# ONLY when no stock key matched. ~$0.03/image. Set to false to disable entirely.
IMAGE_OPENROUTER_ENABLED=true
IMAGE_GENERATION_MODEL=google/gemini-2.5-flash-image

# Storage (local for MVP)
STORAGE_PATH=./storage

# Admin (Telegram)
ADMIN_TELEGRAM_IDS=123456789

# Admin Panel
ADMIN_PHONE=998901234567
ADMIN_PASSWORD=your_secure_password_here
ADMIN_NAME=Admin
JWT_SECRET=your_jwt_secret_key_here

# Pricing
CREDITS_PER_PRESENTATION=1
DEFAULT_FREE_CREDITS=3
